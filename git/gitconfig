[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f

[core]
	autocrlf = input
	editor = code --wait

[init]
	defaultBranch = main

[gpg]
